# Copy this file to .env and fill in the required values:
#   cp .env.example .env

# Environment
NODE_ENV=production
PORT=5000
HOST=0.0.0.0

# Authentication
# Generate a strong secret with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
JWT_EXPIRATION=1d

# Frontend URLs
FRONTEND_URL=http://frontend:3000
FRONTEND_PUBLIC_URL=http://localhost:3000

# MongoDB (uses Docker service name inside containers)
MONGODB_URI=mongodb://mongodb:27017/malaria_lab

# Logging
LOG_LEVEL=info

# Flask Diagnosis API (internal Docker network — do not change)
FLASK_API_URL=http://flask-api:5000
FLASK_API_TIMEOUT=300000
FLASK_API_RETRY_ATTEMPTS=3
FLASK_API_RETRY_DELAY=5000
USE_SHARED_VOLUME=true

# Email notifications (optional — leave blank to disable)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Redis (uses Docker service name — do not change)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# Application
APP_NAME=Malaria Lab System
VERSION=1.0.0

# File Upload
UPLOAD_PATH=/app/uploads
SHARED_UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/jpg,image/png,image/tiff,image/tif
