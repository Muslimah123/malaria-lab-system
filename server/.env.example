# =======================================
# 🌍 Environment
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# =======================================
# 🔐 Authentication
JWT_SECRET=supersecretkey123
JWT_EXPIRATION=1d

# =======================================
# 🌐 Frontend URL
FRONTEND_URL=http://localhost:3000

# =======================================
# 💾 MongoDB
MONGODB_URI=mongodb://localhost:27017/malaria_lab

# =======================================
# 📊 Logging
LOG_LEVEL=info

# =======================================
# 🧬 Flask Diagnosis API
FLASK_API_URL=http://127.0.0.1:5001
FLASK_API_KEY=  # Leave empty if your Flask API doesn’t require one

# =======================================
# 📤 Email (Optional – can be left empty for now)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# =======================================
# 🚀 Additional
# ADDITIONAL_ORIGINS=http://example.com,http://test.com

